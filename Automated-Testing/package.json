{
  "name": "motorambar-e2e-tests",
  "version": "1.0.0",
  "description": "Pruebas E2E automatizadas para Portal Motorambar",
  "scripts": {
    "test": "npx playwright test --headed",
    "test:slow": "cross-env SLOW_MO=800 npx playwright test --headed",
    "test:debug": "cross-env PWDEBUG=1 npx playwright test --headed",
    "test:headless": "npx playwright test",
    "report": "npx playwright show-report",
    "ui": "npx playwright test --ui"
  },
  "keywords": ["playwright", "e2e", "testing"],
  "author": "QA Motorambar",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "typescript": "^5.5.0"
  }
}
